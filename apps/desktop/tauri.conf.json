
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mercury Desktop",
  "version": "0.1.0",
  "identifier": "com.example.mercury",
  "build": {
    "beforeDevCommand": "node ./scripts/start-ui-dev.mjs",
    "beforeBuildCommand": "node ./scripts/prepare-build.mjs",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../packages/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mercury Desktop",
        "width": 1000,
        "height": 700,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "resources": {
      "../../backend/dist/mercury-backend": "binaries"
    },
    "useLocalToolsDir": false
  }
}