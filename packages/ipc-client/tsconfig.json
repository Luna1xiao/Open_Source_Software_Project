{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@mercury/shared-types": ["../shared-types/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
