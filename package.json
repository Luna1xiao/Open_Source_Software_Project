{
  "name": "open-source-software-project",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:ui": "pnpm --filter ui dev",
    "dev:backend": "cd backend && uv run uvicorn app.main:app --reload",
    "dev:desktop": "pnpm --filter desktop tauri:dev",
    "gen:types": "node packages/shared-types/scripts/generate.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
